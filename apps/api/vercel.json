{
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@peec-lab/api",
  "crons": [
    { "path": "/v1/internal/cron/daily-snapshots", "schedule": "0 6 * * *" },
    { "path": "/v1/internal/cron/finalize-due-experiments", "schedule": "0 7 * * *" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
