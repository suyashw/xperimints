# Database (Neon Postgres via Vercel Marketplace)
DATABASE_URL="postgresql://user:password@host:5432/peec_lab?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/peec_lab?sslmode=require"

# Peec MCP — Streamable HTTP endpoint. Authentication is performed entirely
# at runtime via the in-app Connect Peec modal (OAuth 2.1 + PKCE + DCR);
# tokens are kept in-memory only and never written here.
PEEC_MCP_BASE_URL="https://api.peec.ai/mcp"

# Auth — local email/password flow.
# AUTH_SECRET signs the session JWT (HS256). Generate with:
#   openssl rand -hex 32
# Required in production; dev falls back to a stable insecure value if unset.
AUTH_SECRET=""

# Legacy Clerk vars (unused by the in-app email/password flow but kept
# for forward-compat with any future managed-auth integration).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Cross-service
INTERNAL_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="dev-only-rotate-me"

# Integration secrets (envelope encryption master key — 32 bytes base64)
INTEGRATION_KMS_MASTER_KEY=""

# GitHub (single-repo PAT for hackathon; GitHub App later)
GITHUB_WEBHOOK_SECRET=""

# Vercel deploy webhook
VERCEL_WEBHOOK_SECRET=""

# Linear
LINEAR_API_KEY=""

# Upstash Redis (rate limiting + idempotency)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob (OG images, exported reports)
BLOB_READ_WRITE_TOKEN=""
