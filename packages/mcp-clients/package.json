{
  "name": "@peec-lab/mcp-clients",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./peec": {
      "types": "./dist/peec/index.d.ts",
      "default": "./dist/peec/index.js"
    },
    "./peec/fake": {
      "types": "./dist/peec/fake-transport.d.ts",
      "default": "./dist/peec/fake-transport.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'no-op'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
